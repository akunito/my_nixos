# Template for secrets/domains.nix
# Copy this file to secrets/domains.nix and fill in real values
# The actual domains.nix is encrypted with git-crypt
{
  # Primary domains
  publicDomain = "example.com";
  localDomain = "local.example.com";
  wildcardLocal = "local.example.com";

  # Tailscale/Headscale (public domain, not really secret - can be hardcoded in profiles)
  headscaleDomain = "headscale.example.com";

  # External infrastructure
  vpsExternalIp = "0.0.0.0";            # Old VPS public IP (Hetzner, to be decommissioned)
  vpsNetcupIp = "0.0.0.0";             # New Netcup RS 4000 G12 public IP
  vpsNetcupGateway = "0.0.0.0";        # Netcup gateway
  vpsSshPort = 56777;                   # VPS non-standard SSH port (after hardening)
  vpsBootstrapPassword = "";            # Temp bootstrap password - remove after profile deployed
  pfsenseWireguardPubkey = "";          # pfSense WG public key (derive: echo PRIVKEY | wg pubkey)
  pfsenseWireguardPsk = "";             # WG PresharedKey (extra encryption layer)

  # SNMP credentials (v2c - legacy, keep for fallback)
  snmpCommunity = "your-snmp-community-string";

  # SNMPv3 credentials (for Prometheus monitoring - preferred)
  # Used by: prometheus-snmp.nix on LXC_monitoring for pfSense monitoring
  # Configure matching user on pfSense: Services → SNMP (NET-SNMP) → Users
  snmpv3User = "prometheus";
  snmpv3AuthPass = "your-snmpv3-auth-password";
  snmpv3PrivPass = "your-snmpv3-priv-password";

  # Email addresses
  alertEmail = "your-email@example.com";
  acmeEmail = "your-email@example.com";
  notificationFrom = "noreply@example.com";
  grafanaAlertsFrom = "alerts@example.com";

  # SMTP2GO credentials (for postfix relay services)
  smtp2goUser = "your-smtp2go-user@example.com";
  smtp2goPassword = "your-smtp2go-password";

  # Uptime Kuma credentials
  # Kuma 1 (Local - LXC_mailer): http://192.168.8.89:3001
  kuma1Username = "admin";
  kuma1Password = "your-kuma1-password";
  # Kuma 2 (Public - VPS): https://status.akunito.com
  # Get token: Login with 2FA, then run localStorage.getItem('token') in browser console
  kuma2JwtToken = "your-jwt-token-from-browser-devtools";

  # ============================================================================
  # CENTRALIZED DATABASE SERVER (LXC_database - 192.168.8.103)
  # ============================================================================

  # PostgreSQL database passwords
  # Used by: Plane, LiftCraft applications connecting to centralized PostgreSQL
  dbPlanePassword = "your-plane-db-password";
  dbLiftcraftPassword = "your-liftcraft-db-password";

  # MariaDB database passwords
  # Used by: Nextcloud connecting to centralized MariaDB
  dbNextcloudPassword = "your-nextcloud-db-password";

  # n8n database password
  # Used by: n8n workflow automation connecting to PostgreSQL on VPS
  dbN8nPassword = "your-n8n-db-password";

  # n8n admin user credentials (web UI login)
  n8nAdminEmail = "your-n8n-admin-email";
  n8nAdminPassword = "your-n8n-admin-password";
  # n8n API key (for workflow management via API)
  n8nApiKey = "your-n8n-api-key";

  # Matrix database password
  # Used by: Matrix Synapse connecting to centralized PostgreSQL
  dbMatrixPassword = "your-matrix-db-password";

  # Redis server password
  # Used by: Plane (db0), Nextcloud (db1), LiftCraft TEST (db2), Portfolio (db3), Matrix (db4)
  redisServerPassword = "your-redis-server-password";

  # ============================================================================
  # MATRIX SERVER (LXC_matrix - 192.168.8.104)
  # ============================================================================
  # Matrix signing key (IRRECOVERABLE — store in Bitwarden!)
  # Used by: Synapse for federation signatures. If lost, other servers reject our messages.
  matrixSigningKey = ""; # Back up from Synapse container ASAP

  # Matrix bot access token
  # Generated after Synapse setup: register_new_matrix_user, then get token
  matrixBotAccessToken = ""; # Generate after Synapse setup

  # Matrix user accounts
  matrixUsers = {
    example-user = {
      username = "example-user";
      password = "your-matrix-user-password";
      fullId = "@example-user:example.com";
      created = "2026-01-01";
    };
  };

  # ============================================================================
  # GITHUB ACCESS TOKEN (for Nix flake fetching - avoids API rate limits)
  # ============================================================================
  # Generate at: https://github.com/settings/tokens (classic, no scopes needed)
  # Used by: LXC and homelab profiles to fetch flake inputs without rate limiting
  githubAccessToken = "ghp_your-github-token-here";

  # ============================================================================
  # OPENCLAW AI ASSISTANT (VPS Docker service)
  # ============================================================================
  # Perplexity API key (AI-synthesized web search fallback)
  # Used by: OpenClaw web search tool (fallback after Brave Search)
  # Get key: https://www.perplexity.ai/settings/api
  perplexityApiKey = "pplx-your-perplexity-api-key";

  # ============================================================================
  # PFSENSE REST API (for automation and auditing)
  # ============================================================================
  # Install package: ssh admin@192.168.8.1 "pkg-static add https://github.com/pfrest/pfSense-pkg-RESTAPI/releases/download/v2.4.3/pfSense-2.7.2-pkg-RESTAPI.pkg"
  # Create key in: System → REST API → Keys (SHA-512, 64 bytes recommended)
  # Enable auth method: System → REST API → Settings → Authentication Methods → Key
  # Used by: Claude Code for pfSense auditing and automation
  # Header format: x-api-key: <key-value>
  pfsenseApiKey = "your-pfsense-api-key";
  pfsenseApiKeyName = "your-key-name";
  pfsenseHost = "192.168.8.1";

  # ============================================================================
  # NGINX PROXY MANAGER (LXC_proxy - 192.168.8.102)
  # ============================================================================
  # Admin UI: http://192.168.8.102:81
  # Used by: Claude Code for proxy host automation
  npmAdminEmail = "your-npm-admin-email";
  npmAdminPassword = "your-npm-admin-password";

  # ============================================================================
  # HEADSCALE/HEADPLANE (VPS - headscale.example.com)
  # ============================================================================
  # Headscale: https://headscale.example.com (coordination server)
  # Headplane: https://headplane.example.com/admin (web UI)
  # Used by: Headplane web UI authentication
  headscaleApiKey = "your-headscale-api-key";

  # ============================================================================
  # PLANE API (plane.example.com)
  # ============================================================================
  # API token for Plane MCP server integration
  planeApiToken = "your-plane-api-token";
  # Plane admin user credentials (for internal API auth - session-based)
  planeAdminEmail = "your-plane-admin-email";
  planeAdminPassword = "your-plane-admin-password";

  # ============================================================================
  # MEDIA STACK - TRUENAS (192.168.20.200)
  # ============================================================================
  # Bazarr subtitle provider credentials
  addic7edUsername = "your-addic7ed-username";
  addic7edPassword = "your-addic7ed-password";

  # IPTorrents (private tracker)
  iptorrentsUsername = "your-iptorrents-username";
  iptorrentsPassword = "your-iptorrents-password";
  iptorrentsCookie = "uid=XXXX; pass=XXXX";

  # qBittorrent WebUI credentials
  qbittorrentUsername = "admin";
  qbittorrentPassword = "your-qbittorrent-password";

  # ============================================================================
  # NEXUS MODS API (for Jackify/Wabbajack mod downloads)
  # ============================================================================
  # Get key at: https://www.nexusmods.com/users/myaccount?tab=api
  # Used by: Jackify for Wildlander modlist installation
  nexusApiKey = "your-nexus-api-key";

  # ============================================================================
  # UNIFI NETWORK CONTROLLER (LXC_HOME - 192.168.8.80:8443)
  # ============================================================================
  # Admin UI: https://192.168.8.80:8443 or https://unifi.local.example.com
  # Used by: Claude Code for switch port diagnostics and network automation
  # 2FA enabled — direct API login requires session cookie
  unifiEmail = "your-unifi-admin-email";
  unifiPassword = "your-unifi-admin-password";
  # Session cookie for API access (bypasses 2FA)
  # Get: Login to UI with 2FA, extract 'unifises' cookie from browser DevTools
  unifiSessionCookie = "your-unifises-cookie-value";

  # ============================================================================
  # PROMETHEUS HTTP BASIC AUTH (for nginx-local vhost on VPS)
  # ============================================================================
  # Same credentials as control-panel
  # Generated with: htpasswd -nbBC 10 admin "<password>"
  prometheusHtpasswd = "admin:$2y$10$your-bcrypt-hash-here";

  # ============================================================================
  # CLOUDFLARE DNS API TOKEN (for ACME wildcard cert *.local.akunito.com)
  # ============================================================================
  # Create at: https://dash.cloudflare.com/profile/api-tokens
  # Permission: Zone > DNS > Edit (1 zone)
  # Used by: VPS acme.nix (Cloudflare DNS-01 challenge for Let's Encrypt)
  # File on VPS: /etc/secrets/cloudflare-acme (format: CF_DNS_API_TOKEN=<token>)
  cloudflareDnsApiToken = "your-cloudflare-dns-api-token";

  # ============================================================================
  # OPENCLAW AI ASSISTANT (VPS Docker service - port 18789)
  # ============================================================================
  # Gateway auth token (random 64-char hex — used for Web UI access)
  # Generate: openssl rand -hex 32
  openclawGatewayToken = "64-char-hex-token";

  # Webhook hooks token (stored as separate file on VPS, NOT in container env)
  # Generate: openssl rand -hex 32 > ~/.homelab/openclaw/hooks-token
  openclawHooksToken = "64-char-hex-token-for-webhooks";

  # Telegram bot token (from @BotFather)
  openclawTelegramBotToken = "telegram-bot-token";
}
