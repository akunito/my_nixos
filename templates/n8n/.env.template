# n8n Environment Variables
# Copy to ~/.homelab/n8n/.env and fill in values

# Database password (must match NixOS PostgreSQL config in secrets/domains.nix)
N8N_DB_PASSWORD=CHANGE_ME

# Public domain (for webhook URLs via Cloudflare tunnel)
PUBLIC_DOMAIN=akunito.com

# Encryption key for credential storage (generate with: openssl rand -hex 32)
# CRITICAL: Back this up in Bitwarden! Losing it means all stored credentials become unreadable.
N8N_ENCRYPTION_KEY=CHANGE_ME
