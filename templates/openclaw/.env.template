# Alibaba Cloud Model Studio API Key (DashScope international endpoint)
MODELSTUDIO_API_KEY=sk-CHANGE_ME

# OpenClaw webhook hook token — stored as SEPARATE FILE (not in .env)
# Write to ~/.homelab/openclaw/hooks-token (bind-mounted as /run/secrets/hooks_token:ro)
# This keeps the hook token out of the container's env, so MCP subprocesses can't read it.
# Generate: openssl rand -hex 32 > ~/.homelab/openclaw/hooks-token && chmod 600 ~/.homelab/openclaw/hooks-token
# OPENCLAW_HOOKS_TOKEN is NOT injected as env var — see docker-compose.yml volumes.

# Plane API token (restricted -- used by plane-restricted-mcp.py)
PLANE_OPENCLAW_TOKEN=plane_api_CHANGE_ME

# Jellyseerr API key (media recommendations -- TrueNAS)
JELLYSEERR_OPENCLAW_KEY=CHANGE_ME

# GitHub PAT (fine-grained, read + issues + comments)
GITHUB_OPENCLAW_TOKEN=github_pat_CHANGE_ME

# Leftyworkout DB (read-only PostgreSQL user)
LEFTYWORKOUT_DB_URL=postgresql://openclaw_reader:CHANGE_ME@host.docker.internal:5432/rails_database_prod

# Miniflux RSS API key (read feeds and entries)
MINIFLUX_OPENCLAW_KEY=CHANGE_ME
