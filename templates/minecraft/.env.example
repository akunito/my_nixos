# Minecraft Server Environment Variables
# Copy to .env and fill in values before first start

# === Memory (JVM heap) ===
MC_MEMORY=4G

# === Server Settings ===
MC_SERVER_NAME=AkuCraft
MC_MOTD=AkuCraft — Fabric 1.21.1
MC_DIFFICULTY=hard
MC_MAX_PLAYERS=10
MC_VIEW_DISTANCE=12
MC_SIMULATION_DISTANCE=8

# === RCON (admin console, localhost-only) ===
# Generate: openssl rand -hex 16
MC_RCON_PASSWORD=CHANGE_ME
