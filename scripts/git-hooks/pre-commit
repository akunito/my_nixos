#!/usr/bin/env bash
# Pre-commit hook: blocks commits containing potential secrets in unencrypted files.
# Installed by scripts/setup-hooks.sh (symlinked into .git/hooks/).
#
# Checks staged files for:
#   - API key prefixes (GitHub, OpenAI, Perplexity, Grafana, AWS, Hugging Face)
#   - Private key headers (PEM)
#   - High-entropy secret assignments (KEY/TOKEN/SECRET/PASSWORD = "long-value")
#   - NixOS password literals (skips secrets.foo, ${var}, passwordFile)
#   - JWT tokens, Telegram bot tokens, Matrix access tokens
#
# Encrypted files (per git-crypt) are skipped automatically.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
RESET='\033[0m'

# Get list of staged files (added/modified/copied)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Filter out files that are encrypted by git-crypt.
# IMPORTANT: use "not encrypted" (not just "encrypted") to avoid matching both.
UNENCRYPTED_FILES=()
for file in $STAGED_FILES; do
    # Skip files that don't exist (deleted between staging and commit)
    [ -f "$file" ] || continue

    # Check git-crypt status for this file
    # git-crypt status outputs either "    encrypted: <file>" or "not encrypted: <file>"
    # We use "grep -qv 'not encrypted:'" which is WRONG — it would fail on encrypted files too.
    # Correct: check if the line starts with "not encrypted:"
    crypt_status=$(git-crypt status "$file" 2>/dev/null || echo "not encrypted: $file")
    if echo "$crypt_status" | grep -q "^not encrypted:"; then
        UNENCRYPTED_FILES+=("$file")
    fi
done

if [ ${#UNENCRYPTED_FILES[@]} -eq 0 ]; then
    exit 0
fi

BLOCKED=false
FINDINGS=""

for file in "${UNENCRYPTED_FILES[@]}"; do
    # Get staged content (not working tree content)
    CONTENT=$(git show ":$file" 2>/dev/null || true)
    [ -n "$CONTENT" ] || continue

    # --- Check 1: API key prefixes ---
    # GitHub PAT, OpenAI, Perplexity, Grafana SA, AWS, Hugging Face
    if echo "$CONTENT" | grep -nEi '(AIzaSy[0-9A-Za-z_-]{33}|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|pplx-[a-f0-9]{48}|glsa_[a-zA-Z0-9]{32,}|AKIA[0-9A-Z]{16}|hskey-[a-zA-Z0-9]{20,})' > /dev/null 2>&1; then
        matches=$(echo "$CONTENT" | grep -nEi '(AIzaSy[0-9A-Za-z_-]{33}|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|pplx-[a-f0-9]{48}|glsa_[a-zA-Z0-9]{32,}|AKIA[0-9A-Z]{16}|hskey-[a-zA-Z0-9]{20,})')
        FINDINGS+="  ${RED}API key pattern${RESET} in $file:\n$matches\n"
        BLOCKED=true
    fi

    # --- Check 2: Private key headers ---
    if echo "$CONTENT" | grep -nE '-----BEGIN [A-Z ]*(PRIVATE|RSA|EC|DSA) KEY-----' > /dev/null 2>&1; then
        matches=$(echo "$CONTENT" | grep -nE '-----BEGIN [A-Z ]*(PRIVATE|RSA|EC|DSA) KEY-----')
        FINDINGS+="  ${RED}Private key header${RESET} in $file:\n$matches\n"
        BLOCKED=true
    fi

    # --- Check 3: High-entropy secret assignments ---
    # Matches: KEY|TOKEN|SECRET|PASSWORD = "value-at-least-12-chars"
    # Skips: references to secrets.*, ${...}, nix variable interpolation
    if echo "$CONTENT" | grep -nEi '(KEY|TOKEN|SECRET|PASSWORD)\s*=\s*"[^$\{"][^"]{12,}"' > /dev/null 2>&1; then
        # Filter out safe patterns: secrets.foo, passwordFile, hashedPassword (nix module options)
        suspicious=$(echo "$CONTENT" | grep -nEi '(KEY|TOKEN|SECRET|PASSWORD)\s*=\s*"[^$\{"][^"]{12,}"' | grep -viE '(secrets\.|passwordFile|hashedPassword|mkOption|description|example|default =.*lib\.|[0-9]+:\s*#)' || true)
        if [ -n "$suspicious" ]; then
            FINDINGS+="  ${YELLOW}Possible secret assignment${RESET} in $file:\n$suspicious\n"
            BLOCKED=true
        fi
    fi

    # --- Check 4: NixOS password literals ---
    # Catches: password = "literal"; skips secrets.foo, ${var}, passwordFile, hashedPasswordFile
    if echo "$CONTENT" | grep -nE 'password\s*=\s*"[^$\{"][^"]{3,}"' > /dev/null 2>&1; then
        suspicious=$(echo "$CONTENT" | grep -nE 'password\s*=\s*"[^$\{"][^"]{3,}"' | grep -viE '(secrets\.|passwordFile|hashedPassword|mkOption|description|example|# )' || true)
        if [ -n "$suspicious" ]; then
            FINDINGS+="  ${YELLOW}Literal password${RESET} in $file:\n$suspicious\n"
            BLOCKED=true
        fi
    fi

    # --- Check 5: JWT tokens ---
    if echo "$CONTENT" | grep -nE 'eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}\.' > /dev/null 2>&1; then
        matches=$(echo "$CONTENT" | grep -nE 'eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}\.')
        FINDINGS+="  ${RED}JWT token${RESET} in $file:\n$matches\n"
        BLOCKED=true
    fi

    # --- Check 6: Telegram bot tokens ---
    if echo "$CONTENT" | grep -nE '[0-9]{8,10}:[A-Za-z0-9_-]{35}' > /dev/null 2>&1; then
        matches=$(echo "$CONTENT" | grep -nE '[0-9]{8,10}:[A-Za-z0-9_-]{35}')
        FINDINGS+="  ${YELLOW}Possible Telegram bot token${RESET} in $file:\n$matches\n"
        BLOCKED=true
    fi

    # --- Check 7: Matrix access tokens ---
    if echo "$CONTENT" | grep -nE 'syt_[a-zA-Z0-9_]{20,}' > /dev/null 2>&1; then
        matches=$(echo "$CONTENT" | grep -nE 'syt_[a-zA-Z0-9_]{20,}')
        FINDINGS+="  ${RED}Matrix access token${RESET} in $file:\n$matches\n"
        BLOCKED=true
    fi
done

if [ "$BLOCKED" = true ]; then
    echo -e "\n${RED}=== PRE-COMMIT HOOK: POTENTIAL SECRET DETECTED ===${RESET}\n"
    echo -e "$FINDINGS"
    echo -e "${YELLOW}If this is a false positive, commit with --no-verify (use sparingly).${RESET}"
    echo -e "${YELLOW}If this file should be encrypted, add it to .gitattributes with git-crypt.${RESET}\n"
    exit 1
fi

exit 0
