# Copy to .env on the VPS (cd ~/.homelab/openproject-demo) and fill in.
# Generate secrets with:  openssl rand -hex 64   /   openssl rand -base64 24

# Pick the LATEST STABLE OpenProject tag. The self-hosted mobile app needs a
# recent version (OpenProject 17.x line per the mobile FAQ) — verify on Docker Hub
# (hub.docker.com/r/openproject/openproject/tags) before deploying.
OPENPROJECT_TAG=15

# 128-char hex recommended:  openssl rand -hex 64
OPENPROJECT_SECRET_KEY_BASE=

# Initial admin password (user: admin). Change at first login.
OPENPROJECT_ADMIN_PASSWORD=
