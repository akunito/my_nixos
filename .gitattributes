# ============================================================================
# Git Attributes for NixOS Configuration Repository
# ============================================================================
#
# This file configures how git handles specific files during merges and diffs.
#
# ============================================================================

# Unified flake files: keep local flake.lock during pulls/merges to avoid
# conflicts between machines running different Nix versions.
# flake.nix is now a unified file shared across all profiles.
#
# merge=ours: During merge, always use our version (ignore incoming changes)
flake.lock merge=ours

# ============================================================================
# Git-Crypt Encrypted Files
# ============================================================================
# Secrets directory - all .nix and .txt files encrypted
secrets/*.nix filter=git-crypt diff=git-crypt
secrets/*.txt filter=git-crypt diff=git-crypt
secrets/vps/** filter=git-crypt diff=git-crypt

# Exclude template files from encryption (they're public)
secrets/*.template !filter !diff

# Komi's personal secrets (separate git-crypt key)
# To initialize: git-crypt init --key-name komi
# To export key: git-crypt export-key --key-name komi ~/komi-git-crypt-key
secrets/komi/** filter=git-crypt-komi diff=git-crypt-komi

# Exclude komi template files from encryption
secrets/komi/*.template !filter !diff

# Infrastructure internal documentation (sensitive details)
docs/akunito/infrastructure/INFRASTRUCTURE_INTERNAL.md filter=git-crypt diff=git-crypt

# Komi infrastructure internal documentation (sensitive details, komi key)
docs/komi/infrastructure/KOMI_INFRASTRUCTURE_INTERNAL.md filter=git-crypt-komi diff=git-crypt-komi

# TrueNAS migration doc contains iSCSI CHAP credentials
docs/akunito/infrastructure/truenas-migration-complete.md filter=git-crypt diff=git-crypt

# Media stack documentation (service details, provider accounts, API structure)
docs/akunito/infrastructure/services/media-stack.md filter=git-crypt diff=git-crypt

# Deploy config with public IPs (VPS entries)
deploy-servers-private.conf filter=git-crypt diff=git-crypt

